<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Global Neighbors ND — Homepage Mockup v2</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700&family=Nunito:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream:   #faf7f5;
    --yellow:  #f9c326;
    --yellow-dark: #d9a610;
    --sky:     #abdef0;
    --sky-dark: #7fbfd8;
    --green:   #55ad65;
    --green-dark: #3d8a4b;
    --navy:    #002e5d;
    --navy-light: #0a4580;
    --white:   #ffffff;
    --text:    #1a1a2e;
    --text-muted: #5a5a72;
    --radius:  14px;
    --radius-sm: 8px;
  }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    color: var(--text);
    font-size: 16px;
    line-height: 1.65;
  }

  /* ── NAV ── */
  nav {
    background: var(--white);
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,46,93,0.08);
  }

  .nav-logo-img {
    height: 100px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--navy);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 600;
    transition: color 0.15s; opacity: 0.75;
  }

  .nav-links a:hover { color: var(--navy); opacity: 1; }

  .nav-donate {
    background: var(--yellow) !important;
    color: var(--navy) !important;
    padding: 0.5rem 1.25rem !important;
    border-radius: 50px !important;
    font-weight: 700 !important;
    transition: background 0.15s !important;
  }

  .nav-donate:hover { background: var(--yellow-dark) !important; }

  /* ── DROPDOWNS ── */
.has-dropdown {
  position: relative;
}

.has-dropdown > a::after {
  content: ' ▾';
  font-size: 0.7rem;
  opacity: 0.6;
}

.dropdown {
  display: block;
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
  position: absolute;
  top: calc(100% + 12px);
  left: 50%;
  transform: translateX(-50%) translateY(-6px);
  background: var(--navy);
  border-radius: var(--radius-sm);
  list-style: none;
  padding: 0.5rem 0;
  min-width: 210px;
  box-shadow: 0 8px 24px rgba(0,46,93,0.18);
  transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  z-index: 200;
}

/* Invisible bridge so the menu doesn't close when mousing down to it */
.dropdown::before {
  content: '';
  position: absolute;
  top: -12px;
  left: 0;
  right: 0;
  height: 12px;
}

.has-dropdown:hover .dropdown {
  visibility: visible;
  opacity: 1;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}

.dropdown li a {
  display: block;
  padding: 0.5rem 1.25rem;
  color: var(--sky) !important;
  font-size: 0.88rem;
  font-weight: 600;
  opacity: 1 !important;
  transition: background 0.12s, color 0.12s;
  white-space: nowrap;
}

.dropdown li a:hover {
  background: var(--navy-light);
  color: var(--yellow) !important;
}

  /* ── GALA BANNER ── */
  .gala-banner {
    position: relative;
    overflow: hidden;
    min-height: 280px;
  }

  .gala-banner-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 70% center;
    display: block;
  }

  .gala-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,10,30,0.92) 0%, rgba(0,10,30,0.85) 40%, rgba(0,10,30,0.5) 65%, rgba(0,10,30,0.1) 100%);
  }

  .gala-banner-inner {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 280px;
  }

  .gala-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 520px;
  }

  .gala-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--yellow);
    background: rgba(249,195,38,0.15);
    border: 1px solid rgba(249,195,38,0.35);
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
    margin-bottom: 0.75rem;
    width: fit-content;
  }

  .gala-text h2 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.12;
    margin-bottom: 0.5rem;
  }

  .gala-text p {
    color: rgba(255,255,255,0.8);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    max-width: 42ch;
  }

  .btn-navy {
    display: inline-block;
    background: var(--navy);
    color: var(--white);
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.92rem;
    width: fit-content;
    transition: background 0.15s;
  }

  .btn-navy:hover { background: var(--navy-light); }

  .gala-image-col {
    display: flex;
    align-items: stretch;
    position: relative;
    overflow: hidden;
    min-height: 260px;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 600;
    text-align: center;
    padding: 1.5rem;
  }

  .img-placeholder .img-icon {
    width: 40px;
    height: 40px;
    opacity: 0.4;
  }

  /* ── HERO ── */
  .hero-wrap {
    position: relative;
    overflow: hidden;
    min-height: 580px;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,20,50,0.88) 0%, rgba(0,20,50,0.72) 45%, rgba(0,20,50,0.25) 75%, rgba(0,20,50,0.1) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 2.5rem;
    width: 100%;
  }

  .hero-text {
    max-width: 560px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--yellow);
    margin-bottom: 1rem;
  }

  .hero-inner h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-inner h1 em {
    font-style: normal;
    color: var(--yellow);
  }

  .hero-inner h1 .sky-word {
    color: var(--sky);
  }

  .hero-inner h1 .sky-dark-word {
    color: var(--sky-dark);
  }

  .hero-inner p {
    color: rgba(255,255,255,0.82);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 46ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-yellow {
    background: var(--yellow);
    color: var(--navy);
    padding: 0.85rem 1.75rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.15s;
  }

  .btn-yellow:hover { background: var(--yellow-dark); }

  .btn-outline-white {
    border: 2px solid rgba(255,255,255,0.45);
    color: var(--white);
    padding: 0.85rem 1.75rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: border-color 0.15s, background 0.15s;
  }

  .btn-outline-white:hover {
    border-color: rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.08);
  }

  /* ── IMPACT BAR ── */
  .impact-bar {
    background: var(--sky);
    padding: 2.5rem 2.5rem;
  }

  .impact-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }

  .stat-number {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--navy);
    display: block;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(0,46,93,0.65);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.3rem;
    display: block;
  }

  /* ── PROGRAMS ── */
  .programs-wrap {
    background: var(--cream);
    padding: 5rem 2.5rem;
  }

  .programs-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--green);
    margin-bottom: 0.5rem;
    display: block;
  }

  .section-heading {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(1.7rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }

  .section-sub {
    color: var(--text-muted);
    max-width: 54ch;
    margin-bottom: 2.5rem;
    font-size: 1rem;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .program-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    border-top: 5px solid var(--sky);
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 2px 8px rgba(0,46,93,0.06);
  }

  .program-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,46,93,0.12);
  }

  .program-card.c-yellow { border-top-color: var(--yellow); }
  .program-card.c-green  { border-top-color: var(--green); }
  .program-card.c-sky    { border-top-color: var(--sky); }
  .program-card.c-navy   { border-top-color: var(--navy); }

  .program-card h3 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: var(--navy);
  }

  .program-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--navy);
    text-decoration: none;
  }

  /* ── TESTIMONIAL ── */
  .testimonial-wrap {
    background: var(--green);
    padding: 5rem 2.5rem;
  }

  .testimonial-inner {
    max-width: 740px;
    margin: 0 auto;
    text-align: center;
  }

  blockquote {
    font-family: 'Nunito', sans-serif;
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    font-style: italic;
    font-weight: 400;
    color: var(--white);
    line-height: 1.55;
    margin-bottom: 1.5rem;
  }

  .quote-attribution strong {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--white);
    margin-bottom: 0.15rem;
  }

  .quote-attribution span {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
  }

  /* ── GET INVOLVED ── */
  .involve-wrap {
    background: var(--cream);
    padding: 5rem 2.5rem;
  }

  .involve-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .involve-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .involve-card {
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .involve-card.bg-sky    { background: var(--sky); }
  .involve-card.bg-yellow { background: var(--yellow); }
  .involve-card.bg-navy   { background: var(--navy); color: var(--white); }

  .involve-card h3 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .involve-card.bg-navy h3 { color: var(--white); }

  .involve-card p {
    font-size: 0.9rem;
    color: rgba(0,46,93,0.7);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    flex: 1;
  }

  .involve-card.bg-navy p { color: rgba(255,255,255,0.7); }

  .btn-white {
    background: var(--white);
    color: var(--navy);
    padding: 0.65rem 1.4rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    transition: background 0.15s;
  }

  .btn-white:hover { background: var(--cream); }

  .btn-green {
    background: var(--green);
    color: var(--white);
    padding: 0.65rem 1.4rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    transition: background 0.15s;
  }

  .btn-green:hover { background: var(--green-dark); }

  /* ── FOOTER ── */
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.65);
    padding: 3.5rem 2.5rem 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 1.5rem;
  }

  footer h4 {
    font-family: 'Bricolage Grotesque', sans-serif;
    color: var(--white);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .footer-brand p {
    font-size: 0.88rem;
    line-height: 1.65;
    max-width: 30ch;
    margin-bottom: 1rem;
  }

  .footer-tagline {
    display: inline-block;
    background: var(--yellow);
    color: var(--navy);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
    letter-spacing: 0.03em;
  }

  footer ul { list-style: none; }

  footer ul li { margin-bottom: 0.5rem; }

  footer ul a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 0.15s;
  }

  footer ul a:hover { color: var(--white); }

  .footer-address {
    font-size: 0.82rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .footer-address strong {
    display: block;
    color: var(--white);
    font-size: 0.85rem;
    margin-bottom: 0.1rem;
  }

  .footer-bottom {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
  }
</style>
</head>
<body>

