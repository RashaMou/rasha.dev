</div>


<!-- ── IMPACT BAR ── -->
<div class="impact-bar">
  <div class="impact-inner">
    <div>
      <span class="stat-number">500+</span>
      <span class="stat-label">New Americans served</span>
    </div>
    <div>
      <span class="stat-number">200+</span>
      <span class="stat-label">Active volunteers</span>
    </div>
    <div>
      <span class="stat-number">15+</span>
      <span class="stat-label">Years in the community</span>
    </div>
    <div>
      <span class="stat-number">30+</span>
      <span class="stat-label">Languages spoken</span>
    </div>
  </div>
</div>

<!-- ── PROGRAMS ── -->
<div class="programs-wrap">
  <div class="programs-inner">
    <span class="section-eyebrow">How We Help</span>
    <h2 class="section-heading">Programs &amp; Services</h2>
    <p class="section-sub">Free and low-cost programs for New Americans in Bismarck, from one-on-one mentorship and youth support to Spanish classes, community events, and an affordable thrift store.</p>
    <div class="programs-grid">

      <a href="#" class="program-card c-yellow">
        <h3>Mentorship</h3>
        <p>One-on-one mentorship connecting New Americans with established community members for guidance, friendship, and real-life support.</p>
        <span class="card-link">Learn more →</span>
      </a>

      <a href="#" class="program-card c-green">
        <h3>Youth Development</h3>
        <p>School support and mentoring for young New Americans ages 12–24, helping them build confidence, skills, and community roots.</p>
        <span class="card-link">Learn more →</span>
      </a>

      <a href="#" class="program-card c-sky">
        <h3>Community Spanish Classes</h3>
        <p>Conversational Spanish classes open to all, whether you studied it in high school, work with Spanish speakers, or want to connect with your neighbors.</p>
        <span class="card-link">See the schedule →</span>
      </a>

      <a href="#" class="program-card c-navy">
        <h3>Community Resources</h3>
        <p>Links to trusted local organizations offering food assistance, employment support, and more for New Americans in the Bismarck area.</p>
        <span class="card-link">View resources →</span>
