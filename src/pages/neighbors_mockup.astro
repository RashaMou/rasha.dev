<!-- ── HERO ── -->
<div class="hero-wrap">
  <img src="data:image/jpeg;base64," alt="Community member in traditional dress at a Global Neighbors event" class="hero-bg">
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-eyebrow">✦ Bismarck, North Dakota</div>
      <h1>Sharing <em>language</em>, <span class="sky-word">culture</span>, and <span class="sky-dark-word">community</span></h1>
      <p>Global Neighbors brings individuals and organizations together in order to foster a welcoming community for New Americans and English Learners in North Dakota. We believe that extending welcome to our newest neighbors is the best way to grow new generations of neighborly, successful, community-minded Americans.
      <div class="hero-actions">
        <a href="#" class="btn-yellow">Find Help &amp; Services</a>
        <a href="#" class="btn-outline-white">Get Involved</a>
      </div>
    </div>
  </div>
</div>


<!-- ── GALA BANNER ── -->
<div class="gala-banner">
    <img src="data:image/jpeg;base64," alt="Global Gala 2026" class="gala-banner-bg">
  <div class="gala-banner-overlay"></div>
  <div class="gala-banner-inner">
    <div class="gala-text">
      <div class="gala-eyebrow">🎟 Upcoming Event — April 23, 2026</div>
      <h2>Global Gala 2026</h2>
      <p>An unforgettable evening of global flavors, inspiring stories, and community at the North Dakota Heritage Center. Dress code: Global Radiance.</p>
      <a href="#" class="btn-yellow">Get Tickets</a>
    </div>
